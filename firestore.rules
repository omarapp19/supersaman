rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección de pasillos (aisles)
    match /aisles/{aisleId} {
      allow read, write: if true;

      // Reglas para la subcolección de productos dentro de cada pasillo
      match /products/{productId} {
        allow read, write: if true;
      }
    }

    // Reglas para la colección de pedidos/órdenes de compra (orders)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Reglas para la colección de perfiles de usuario (users)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Reglas para la colección de cabezales (alquiler de puntas de góndola)
    match /cabezales/{cabezalId} {
      allow read, write: if true;

      // Historial de períodos de pago de cada cabezal
      match /pagos/{pagoId} {
        allow read, write: if true;
      }
    }

    // Reglas para las órdenes de compra (ODC)
    match /purchaseOrders/{orderId} {
      allow read, write: if true;
    }

    // Reglas para configuración general de la app (ej. tope semanal de ODC)
    match /config/{configId} {
      allow read, write: if true;
    }
  }
}
